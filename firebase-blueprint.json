{
  "entities": {
    "users": {
      "title": "User",
      "description": "User profile and approval status",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User role" },
        "isApproved": { "type": "boolean", "description": "Whether the user is approved by admin" },
        "generationCount": { "type": "integer", "description": "Total number of generations performed by the user", "default": 0 },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation time" }
      },
      "required": ["uid", "email", "isApproved"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profile documents"
    }
  }
}
